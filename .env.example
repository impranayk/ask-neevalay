# --- Ask Neevalay : configuration ---
# Copy this file to ".env" and fill in your values. Never commit the real .env.

# Free key from https://console.groq.com/keys
GROQ_API_KEY=
# Optional 2nd key from a SEPARATE Groq account, for daily-limit failover:
# GROQ_API_KEY2=

# Optional overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# RAG_TOP_K=5
# RAG_MIN_SCORE=0.25

# --- Optional: leads + question analytics (see EMBED_AND_DB.md) ---
# SUPABASE_URL=https://YOURPROJECT.supabase.co
# SUPABASE_KEY=your-service_role-key
# LEAD_WEBHOOK_URL=            # POST each lead here for a WhatsApp/email alert
# MAX_MESSAGES_PER_SESSION=25  # abuse guard on the public endpoint
